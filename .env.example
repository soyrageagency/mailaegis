# MailAegis — copy to .env and fill in what you need.
# Everything here is optional: with none of it set, MailAegis still runs and
# analyses mail with its own engine.
# Crafted by SoyRage Agency — https://soyrage.es/

# --- Set this ---------------------------------------------------------------
# Your domains. Without them the impersonation and look-alike rules have
# nothing to protect, which is most of the BEC detection.
MAILAEGIS_CORPORATE_DOMAINS=corp.example,corp.co.uk

# The container binds 0.0.0.0, so anything that reaches the port reaches the
# API. Set a token unless it sits behind an authenticating proxy.
MAILAEGIS_API_TOKEN=

# --- Scanners ---------------------------------------------------------------
# ClamAV is wired up by docker-compose; these are the optional cloud lookups.
# Only hashes, URL identifiers and the originating IP are ever sent.
VIRUSTOTAL_API_KEY=
HYBRID_ANALYSIS_API_KEY=

# --- Mailbox ----------------------------------------------------------------
# Optional: the web UI can ask for these instead, so credentials never have to
# live in a file.
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# Microsoft 365 or Google without an app password. Run `mailaegis oauth` to
# get the refresh token.
OAUTH_PROVIDER=
OAUTH_CLIENT_ID=
OAUTH_REFRESH_TOKEN=
OAUTH_TENANT=

# --- Where decisions are recorded -------------------------------------------
MAILAEGIS_WEBHOOK_URL=
MAILAEGIS_WEBHOOK_TOKEN=

# Air-gapped? false makes no outbound request at all.
MAILAEGIS_UPDATE_CHECK=true
