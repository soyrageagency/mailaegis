# Keep the build context small and, more importantly, keep secrets and build
# artefacts out of it entirely.
# Crafted by SoyRage Agency — https://soyrage.es/

.git
.github
node_modules
dist
*.tsbuildinfo

# Never let a local .env reach the build context — an ARG or a stray COPY
# would bake a VirusTotal key into a layer.
.env
.env.*
reports/
.smoke-*

# The desktop and mobile shells are packaged by their own workflows.
desktop/
mobile/
assets/screenshots/

Dockerfile
docker-compose.yml
README.md
